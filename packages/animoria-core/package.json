{
  "name": "@animoria/core",
  "version": "0.2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./i18n": {
      "types": "./dist/i18n/locales.d.ts",
      "import": "./dist/i18n/locales.js",
      "default": "./dist/i18n/locales.js"
    },
    "./parsers": {
      "types": "./dist/parsers/index.d.ts",
      "import": "./dist/parsers/index.js",
      "default": "./dist/parsers/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^3.2.6",
    "typescript": "^5.0.0",
    "vitest": "^3.2.6"
  },
  "vitest": {
    "include": [
      "tests/**/*.test.ts"
    ]
  },
  "dependencies": {
    "@dotlottie/dotlottie-js": "^1.6.3",
    "fast-glob": "^3.3.3",
    "fflate": "^0.8.3",
    "puppeteer-core": "^25.1.0"
  }
}
